{
  "manifest_version": 3,
  "name": "ApplyMatrix – AI Job Assistant",
  "version": "1.0.0",
  "description": "AI-powered job application assistant. Extract job details, tailor resumes, generate cover letters, and check ATS scores using Gemini AI.",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.naukri.com/*",
    "*://*.indeed.com/*",
    "*://*/*"
  ],
  "action": {
    "default_title": "ApplyMatrix",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.naukri.com/*",
        "*://*.indeed.com/viewjob*",
        "*://*.indeed.com/jobs*",
        "*://*/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
